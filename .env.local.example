# ─── Firebase Client SDK (public — safe to expose in browser) ────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyCTM2dhEVY5lFq7bNkIR7Gne-phh0nABXQ
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=update1-b4bf5.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=update1-b4bf5
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=update1-b4bf5.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1049308656123
NEXT_PUBLIC_FIREBASE_APP_ID=1:1049308656123:web:c966f04f25a0322ac71b5e
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://update1-b4bf5-default-rtdb.firebaseio.com

# ─── Firebase Admin SDK (server-only — NEVER expose to browser) ───────────────
# Get these from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_ADMIN_PROJECT_ID=update1-b4bf5
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxx@update1-b4bf5.iam.gserviceaccount.com
# Paste the private key exactly as it appears in the JSON file (including \n characters)
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# ─── FCM Web Push (VAPID key) ─────────────────────────────────────────────────
# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates → Generate key pair
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_key_here

# ─── Session ──────────────────────────────────────────────────────────────────
# Any random secret string (min 32 chars) for signing session cookies
SESSION_SECRET=change_me_to_a_long_random_secret_string_at_least_32_chars

# ─── Cloudinary (review images + videos) ─────────────────────────────────────
# Dashboard → Settings → Upload → Add upload preset → set to Unsigned
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=alfonex_reviews

# ─── Admin API ────────────────────────────────────────────────────────────────
# Secret token used by the admin panel to call /api/admin/orders/[id]
# Generate: openssl rand -hex 32
ADMIN_SECRET=change_me_to_a_long_random_secret_string

# ─── Admin Panel (Next.js gate) ───────────────────────────────────────────────
# 6-digit PIN shown on the admin login screen (server-side only, never sent to browser)
ADMIN_PASSWORD=123456
# Secret for signing the admin session JWT — generate: openssl rand -hex 32
ADMIN_JWT_SECRET=change_me_to_a_random_32char_or_longer_string
# Cloudinary upload preset used by the admin panel
ADMIN_CLD_PRESET=Alfonex
# Public base URL of this app (used inside the admin HTML for API calls)
NEXT_PUBLIC_SITE_URL=https://alfonex.com
